{
	"name": "@kavsingh/electron-typed-ipc",
	"version": "1.0.0-dev.0",
	"description": "typed electron ipc",
	"keywords": [
		"electron",
		"intent",
		"ipc",
		"skills",
		"tanstack-intent",
		"type-safe"
	],
	"license": "MIT",
	"author": "<author>",
	"files": [
		"dist",
		"skills"
	],
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/common.d.ts",
				"default": "./dist/common.js"
			}
		},
		"./preload": {
			"types": "./dist/preload.d.cts",
			"default": "./dist/preload.cjs"
		},
		"./main": {
			"import": {
				"types": "./dist/main.d.mts",
				"default": "./dist/main.mjs"
			}
		},
		"./renderer": {
			"import": {
				"types": "./dist/renderer.d.ts",
				"default": "./dist/renderer.js"
			}
		},
		"./test/renderer": {
			"import": {
				"types": "./dist/test-renderer.d.ts",
				"default": "./dist/test-renderer.js"
			}
		}
	},
	"scripts": {
		"tdd": "vitest --typecheck --reporter=verbose",
		"test": "vitest run --typecheck --coverage",
		"lint": "oxlint --type-aware --type-check && oxfmt . --check",
		"build": "tsdown",
		"typeinst": "pnpm tsc --extendedDiagnostics | grep Instantiations:"
	},
	"devDependencies": {
		"@tanstack/intent": "catalog:",
		"@tsconfig/node22": "22.0.5",
		"@types/node22": "npm:@types/node@22.19.15",
		"@vitest/coverage-v8": "4.1.4",
		"electron": "catalog:",
		"tsdown": "catalog:",
		"typescript": "6.0.2",
		"vitest": "4.1.4"
	},
	"peerDependencies": {
		"electron": ">=38"
	}
}
